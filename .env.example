# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Gmail SMTP
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (requires 2FA to be enabled on your Google account)
SMTP_USER=your.email@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Recipient(s) — comma-separated for multiple
SMTP_TO=recipient@example.com

# Digest behaviour
MIN_RELEVANCE_SCORE=7        # articles below this score are dropped
MAX_ARTICLES_PER_SECTION=5   # max articles per section (India / Global BFSI / Startups)
LOOKBACK_HOURS=24            # how many hours back to look for articles
